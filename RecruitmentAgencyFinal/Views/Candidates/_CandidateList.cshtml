@model List<RecruitmentAgency.Models.Candidate>

@if (Model != null && Model.Count > 0)
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>ID</th>
                <th>ФИО</th>
                <th>Должность</th>
                <th>Email</th>
                <th>Телефон</th>
                <th>Дата заявки</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr id="candidateRow_@item.Id">
                    <td>@item.Id</td>
                    <td>@item.FullName</td>
                    <td>@item.Position</td>
                    <td>@item.Email</td>
                    <td>@item.Phone</td>
                    <td>@item.ApplicationDate.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>
                        @Html.ActionLink("Детали", "Details", new { id = item.Id }, new { @class = "btn btn-info btn-xs" })
                        @if (Session["UserId"] != null)
                        {
                            @Html.ActionLink("Редактировать", "Edit", new { id = item.Id }, new { @class = "btn btn-warning btn-xs" })
                            @Html.ActionLink("Удалить", "Delete", new { id = item.Id }, new { @class = "btn btn-danger btn-xs" })
                            <button class="btn btn-danger btn-xs" onclick="deleteCandidateAjax(@item.Id)">Удалить (AJAX)</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info">
        <strong>Информация!</strong> Кандидаты не найдены.
    </div>
}