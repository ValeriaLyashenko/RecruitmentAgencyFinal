@model List<RecruitmentAgencyFinal.Models.Resume>

@{
    ViewBag.Title = "Все резюме";
}

<h2>Все резюме соискателей</h2>

@if (Model != null && Model.Count > 0)
{
    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>ID</th>
                <th>ФИО</th>
                <th>Должность</th>
                <th>Опыт</th>
                <th>Зарплата</th>
                <th>Email</th>
                <th>Телефон</th>
                <th>Статус</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @item.Id
                </td>
                <td>
                    @item.FullName
            </td>
            <td>@item.Position
        </td>
        <td>@item.Experience лет
</td>
<td>
    @item.ExpectedSalary.ToString("C0")
</td>
<td>
    @item.Email
</td>
<td>
    @item.Phone
</td>
<td>
    @if (item.Status == "Active")
    {
        <span class="badge bg-success">Активно</span>
    }
    else
    {
        <span class="badge bg-secondary">Неактивно</span>
    }
</td>
<td>
    <a href="@Url.Action("Details", "Resume", new { id = item.Id })" class="btn btn-info btn-sm">Подробнее</a>
</td>
</tr>
}
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info">Резюме не найдены.</div>
}